<Window x:Class="StormV.Views.AddServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:StormV.Views"
        Title="Добавить сервер"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SV.BackgroundDeepBrush}"
        TextElement.Foreground="{StaticResource SV.TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <views:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Border Padding="24">
        <StackPanel>

            <!-- Заголовок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="ServerPlus"
                                          Width="26" Height="26"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0">
                    <materialDesign:PackIcon.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF7B61FF" Offset="0"/>
                            <GradientStop Color="#FF60A5FA" Offset="1"/>
                        </LinearGradientBrush>
                    </materialDesign:PackIcon.Foreground>
                </materialDesign:PackIcon>
                <TextBlock Text="Добавить сервер"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Поддерживаемые протоколы -->
            <TextBlock Margin="0,0,0,14"
                       FontSize="12"
                       Foreground="{StaticResource SV.TextSecondaryBrush}">
                Поддерживаются:
                <Run Foreground="{StaticResource SV.AccentPurpleBrush}"
                     FontWeight="Medium">VLESS · VMess · SS · Trojan · Hysteria2 · TUIC · WireGuard</Run>
            </TextBlock>

            <!-- Поле URL -->
            <TextBox materialDesign:HintAssist.Hint="Вставьте ссылку (vless://, ss://, ...)"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="False"
                     MinHeight="56"
                     FontSize="14"
                     Margin="0,0,0,12"
                     x:Name="UrlBox"/>

            <!-- Кнопки действий под полем -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <!-- Вставить из буфера -->
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding PasteFromClipboardCommand}"
                        Height="36"
                        Margin="0,0,8,0"
                        BorderBrush="{StaticResource SV.AccentPurpleBrush}"
                        Foreground="{StaticResource SV.AccentPurpleBrush}"
                        ToolTip="Вставить ссылку из буфера обмена">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentPaste"
                                                  Width="18" Height="18"
                                                  Margin="0,0,6,0"
                                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Вставить из буфера" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Очистить -->
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Width="36" Height="36"
                        ToolTip="Очистить поле"
                        Foreground="{StaticResource SV.TextSecondaryBrush}"
                        Command="{Binding ClearUrlCommand}">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                </Button>
            </StackPanel>

            <!-- Сообщение об ошибке -->
            <Border Margin="0,0,0,16"
                    Background="#33FF4444"
                    CornerRadius="8"
                    Padding="12,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                              Width="18" Height="18"
                                              Foreground="{StaticResource SV.ErrorBrush}"
                                              VerticalAlignment="Top"
                                              Margin="0,1,8,0"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource SV.ErrorBrush}"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Кнопки Добавить / Отмена -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Отмена"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="44"
                        Command="{Binding CancelCommand}"
                        Foreground="{StaticResource SV.TextSecondaryBrush}"
                        BorderBrush="{StaticResource SV.TextSecondaryBrush}"/>

                <Button Grid.Column="2"
                        Content="Добавить"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="44"
                        Command="{Binding ConfirmCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        FontWeight="Bold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF7B61FF" Offset="0"/>
                            <GradientStop Color="#FF60A5FA" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
