<Window x:Class="StormV.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="StormV — Логи"
        Width="760" Height="520"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SV.BackgroundDeepBrush}"
        TextElement.Foreground="{StaticResource SV.TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Тулбар -->
            <RowDefinition Height="*"/>     <!-- Список логов -->
            <RowDefinition Height="Auto"/>  <!-- Строка статуса -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="{StaticResource SV.BackgroundCardBrush}"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Фильтр по уровню -->
                <ComboBox Grid.Column="0"
                          x:Name="LevelFilter"
                          Width="110"
                          SelectedIndex="1"
                          SelectionChanged="LevelFilter_Changed"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Уровень"
                          FontSize="13">
                    <ComboBoxItem Content="Все (DEBUG+)"/>
                    <ComboBoxItem Content="INFO+"/>
                    <ComboBoxItem Content="WARNING+"/>
                    <ComboBoxItem Content="ERROR"/>
                </ComboBox>

                <!-- Поиск -->
                <TextBox Grid.Column="2"
                         x:Name="SearchBox"
                         materialDesign:HintAssist.Hint="Поиск..."
                         materialDesign:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="13"
                         TextChanged="SearchBox_Changed"/>

                <!-- Кнопки -->
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Прокрутить вниз"
                            Click="ScrollToBottom_Click"
                            Foreground="{StaticResource SV.TextSecondaryBrush}">
                        <materialDesign:PackIcon Kind="ArrowDown" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Копировать всё"
                            Click="CopyAll_Click"
                            Foreground="{StaticResource SV.TextSecondaryBrush}">
                        <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Открыть файл лога"
                            Click="OpenFile_Click"
                            Foreground="{StaticResource SV.TextSecondaryBrush}">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Очистить"
                            Click="Clear_Click"
                            Foreground="{StaticResource SV.TextSecondaryBrush}">
                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                    </Button>
                    <ToggleButton x:Name="AutoScrollToggle"
                                  Style="{StaticResource MaterialDesignActionToggleButton}"
                                  IsChecked="True"
                                  ToolTip="Автопрокрутка"
                                  Width="32" Height="32"
                                  Foreground="{StaticResource SV.AccentPurpleBrush}">
                        <materialDesign:PackIcon Kind="ArrowCollapseDown" Width="16" Height="16"/>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Log list ── -->
        <ListView Grid.Row="1"
                  x:Name="LogList"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="12,3"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#11FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="85"/>   <!-- Время -->
                            <ColumnDefinition Width="40"/>   <!-- Уровень -->
                            <ColumnDefinition Width="80"/>   <!-- Тег -->
                            <ColumnDefinition Width="*"/>    <!-- Сообщение -->
                        </Grid.ColumnDefinitions>

                        <!-- Время -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Time, StringFormat=HH:mm:ss.fff}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#666688"/>

                        <!-- Уровень -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LevelLabel}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="4,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="0">
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="1">
                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="2">
                                            <Setter Property="Foreground" Value="#FBBF24"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="3">
                                            <Setter Property="Foreground" Value="#FF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Тег -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Tag}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#A78BFA"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Сообщение -->
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Message}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{StaticResource SV.TextPrimaryBrush}"
                                   TextWrapping="NoWrap"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Статусная строка ── -->
        <Border Grid.Row="2"
                Background="{StaticResource SV.BackgroundCardBrush}"
                Padding="12,5">
            <Grid>
                <TextBlock x:Name="StatusText"
                           FontSize="12"
                           Foreground="{StaticResource SV.TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right"
                           FontSize="12"
                           Foreground="{StaticResource SV.TextSecondaryBrush}"
                           VerticalAlignment="Center">
                    <Run Text="Файл: "/>
                    <Run x:Name="LogFilePathRun" Text=""/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
