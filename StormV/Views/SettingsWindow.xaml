<Window x:Class="StormV.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Настройки — StormV"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SV.BackgroundDeepBrush}"
        TextElement.Foreground="{StaticResource SV.TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Border Padding="24">
        <StackPanel>

            <!-- Заголовок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24"
                                          VerticalAlignment="Center" Margin="0,0,10,0"
                                          Foreground="{StaticResource SV.AccentPurpleBrush}"/>
                <TextBlock Text="Настройки" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- DNS -->
            <TextBlock Text="DNS серверы" FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource SV.TextSecondaryBrush}" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Основной DNS"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding DnsPrimary, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"/>
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Запасной DNS"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding DnsSecondary, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"/>
            </Grid>

            <!-- Автоподключение -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              IsChecked="{Binding AutoConnectOnStart}"
                              Foreground="{StaticResource SV.AccentPurpleBrush}"/>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Автоподключение при запуске"
                               FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="Подключаться к последнему серверу при старте"
                               FontSize="12" Foreground="{StaticResource SV.TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Bypass list -->
            <TextBlock Text="Bypass (не через VPN)" FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource SV.TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBox materialDesign:HintAssist.Hint="192.168.0.0/16&#x0a;10.0.0.0/8"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding BypassText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13"
                     FontFamily="Consolas"
                     Margin="0,0,0,8"/>
            <TextBlock Text="Каждый CIDR или IP с новой строки"
                       FontSize="11" Foreground="{StaticResource SV.TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Кнопки -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Сбросить"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding ResetDefaultsCommand}"
                        Foreground="{StaticResource SV.TextSecondaryBrush}"/>

                <Button Grid.Column="2"
                        Content="Отмена"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding CancelCommand}"
                        Height="44" Width="100"
                        Foreground="{StaticResource SV.TextSecondaryBrush}"
                        BorderBrush="{StaticResource SV.TextSecondaryBrush}"/>

                <Button Grid.Column="4"
                        Content="Сохранить"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SaveCommand}"
                        Height="44" Width="120"
                        FontWeight="Bold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF7B61FF" Offset="0"/>
                            <GradientStop Color="#FF60A5FA" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
