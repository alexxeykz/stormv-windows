<Application x:Class="StormV.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:StormV.Views"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="DeepPurple"
                                             SecondaryColor="Blue"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Цвета StormV -->
            <Color x:Key="SV.BackgroundDeep">#FF0D0D1A</Color>
            <Color x:Key="SV.BackgroundCard">#FF161628</Color>
            <Color x:Key="SV.AccentPurple">#FF7B61FF</Color>
            <Color x:Key="SV.AccentBlue">#FF60A5FA</Color>
            <Color x:Key="SV.Success">#FF4ADE80</Color>
            <Color x:Key="SV.Error">#FFFF4444</Color>
            <Color x:Key="SV.TextPrimary">#FFFFFFFF</Color>
            <Color x:Key="SV.TextSecondary">#FF9CA3AF</Color>

            <SolidColorBrush x:Key="SV.BackgroundDeepBrush" Color="{StaticResource SV.BackgroundDeep}"/>
            <SolidColorBrush x:Key="SV.BackgroundCardBrush" Color="{StaticResource SV.BackgroundCard}"/>
            <SolidColorBrush x:Key="SV.AccentPurpleBrush" Color="{StaticResource SV.AccentPurple}"/>
            <SolidColorBrush x:Key="SV.AccentBlueBrush" Color="{StaticResource SV.AccentBlue}"/>
            <SolidColorBrush x:Key="SV.SuccessBrush" Color="{StaticResource SV.Success}"/>
            <SolidColorBrush x:Key="SV.ErrorBrush" Color="{StaticResource SV.Error}"/>
            <SolidColorBrush x:Key="SV.TextPrimaryBrush" Color="{StaticResource SV.TextPrimary}"/>
            <SolidColorBrush x:Key="SV.TextSecondaryBrush" Color="{StaticResource SV.TextSecondary}"/>

            <!-- Градиент для логотипа -->
            <LinearGradientBrush x:Key="SV.LogoGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF7B61FF" Offset="0"/>
                <GradientStop Color="#FFA78BFA" Offset="0.5"/>
                <GradientStop Color="#FF60A5FA" Offset="1"/>
            </LinearGradientBrush>

            <!-- Конвертеры -->
            <views:IpMaskConverter x:Key="IpMask"/>

            <!-- Стиль карточки -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SV.BackgroundCardBrush}"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="20"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
