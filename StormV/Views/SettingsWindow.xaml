<Window x:Class="StormV.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:StormV.Views"
        Title="Настройки — StormV"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource SV.BackgroundDeepBrush}"
        TextElement.Foreground="{StaticResource SV.TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <views:InverseBoolConverter x:Key="InverseBool"/>
        <views:BoolToCheckTextConverter x:Key="BoolToCheckText"/>
    </Window.Resources>

    <Border Padding="24">
        <StackPanel>

            <!-- Заголовок -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24"
                                          VerticalAlignment="Center" Margin="0,0,10,0"
                                          Foreground="{StaticResource SV.AccentPurpleBrush}"/>
                <TextBlock Text="Настройки" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- DNS -->
            <TextBlock Text="DNS серверы" FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource SV.TextSecondaryBrush}" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Основной DNS"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding DnsPrimary, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"/>
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Запасной DNS"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding DnsSecondary, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"/>
            </Grid>

            <!-- Автоподключение -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              IsChecked="{Binding AutoConnectOnStart}"
                              Foreground="{StaticResource SV.AccentPurpleBrush}"/>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Автоподключение при запуске"
                               FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="Подключаться к последнему серверу при старте"
                               FontSize="12" Foreground="{StaticResource SV.TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Bypass list -->
            <TextBlock Text="Bypass (не через VPN)" FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource SV.TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBox materialDesign:HintAssist.Hint="192.168.0.0/16&#x0a;10.0.0.0/8"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding BypassText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13"
                     FontFamily="Consolas"
                     Margin="0,0,0,8"/>
            <TextBlock Text="Каждый CIDR или IP с новой строки"
                       FontSize="11" Foreground="{StaticResource SV.TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Proxy domains -->
            <TextBlock Text="Сайты через VPN" FontSize="13" FontWeight="Medium"
                       Foreground="{StaticResource SV.TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBox materialDesign:HintAssist.Hint="instagram.com&#x0a;facebook.com&#x0a;twitter.com"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding ProxyDomainsText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     Height="120"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13"
                     FontFamily="Consolas"
                     Margin="0,0,0,8"/>
            <TextBlock Text="Каждый домен с новой строки. Telegram и YouTube добавлены автоматически."
                       FontSize="11" Foreground="{StaticResource SV.TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- ── Версии и обновления ──────────────────────────────────────────── -->
            <Border Background="{StaticResource SV.BackgroundCardBrush}"
                    CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Версии и обновления"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource SV.TextSecondaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- Текущие версии -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource SV.TextSecondaryBrush}">
                            <Run Text="Приложение: "/>
                            <Run Text="{Binding AppVersion, Mode=OneWay}" FontWeight="Medium"
                                 Foreground="{StaticResource SV.TextPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource SV.TextSecondaryBrush}">
                            <Run Text="sing-box: "/>
                            <Run Text="{Binding SingBoxVersion, Mode=OneWay}" FontWeight="Medium"
                                 Foreground="{StaticResource SV.TextPrimaryBrush}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Статус проверки -->
                    <TextBlock Text="{Binding UpdateStatusText}"
                               FontSize="12" Foreground="{StaticResource SV.AccentPurpleBrush}"
                               Margin="0,0,0,10" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateStatusText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Прогресс скачивания sing-box -->
                    <ProgressBar Value="{Binding SingBoxDownloadProgress}"
                                 Height="4" Margin="0,0,0,10"
                                 Foreground="{StaticResource SV.AccentPurpleBrush}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUpdatingSingBox}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- Кнопки -->
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="{Binding IsCheckingUpdates, Converter={StaticResource BoolToCheckText}}"
                                Command="{Binding CheckUpdatesCommand}"
                                IsEnabled="{Binding IsCheckingUpdates, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="36" Margin="0,0,8,0"
                                BorderBrush="{StaticResource SV.AccentPurpleBrush}"
                                Foreground="{StaticResource SV.AccentPurpleBrush}"/>

                        <Button Content="Обновить sing-box"
                                Command="{Binding UpdateSingBoxCommand}"
                                IsEnabled="{Binding CanUpdateSingBox}"
                                Height="36" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SingBoxUpdateAvailable}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF7B61FF" Offset="0"/>
                                    <GradientStop Color="#FF60A5FA" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>

                        <Button Content="Скачать новую версию приложения"
                                Command="{Binding DownloadAppCommand}"
                                Height="36">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppUpdateAvailable}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF7B61FF" Offset="0"/>
                                    <GradientStop Color="#FF60A5FA" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Сбросить"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding ResetDefaultsCommand}"
                        Foreground="{StaticResource SV.TextSecondaryBrush}"/>

                <Button Grid.Column="2"
                        Content="Отмена"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding CancelCommand}"
                        Height="44" Width="100"
                        Foreground="{StaticResource SV.TextSecondaryBrush}"
                        BorderBrush="{StaticResource SV.TextSecondaryBrush}"/>

                <Button Grid.Column="4"
                        Content="Сохранить"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SaveCommand}"
                        Height="44" Width="120"
                        FontWeight="Bold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF7B61FF" Offset="0"/>
                            <GradientStop Color="#FF60A5FA" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>

            <!-- Разделитель и кнопка выхода -->
            <Separator Margin="0,20,0,12" Opacity="0.2"/>
            <Button Content="Выйти из приложения"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding ExitCommand}"
                    HorizontalAlignment="Center"
                    Height="40"
                    Foreground="{StaticResource SV.ErrorBrush}"
                    BorderBrush="{StaticResource SV.ErrorBrush}"/>

        </StackPanel>
    </Border>
</Window>
